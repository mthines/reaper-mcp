# OpenTelemetry — REAPER MCP Server
#
# Copy this file to .env.otel and fill in your auth token:
#   cp .env.otel.example .env.otel
#
# Then run:
#   pnpm start:otel        (production build)
#   pnpm dev:otel           (dev with watch mode)
#
# Get your Dash0 auth token at:
#   https://app.dash0.com/settings/auth-tokens (Ingesting permission)

# ── Required: set your Dash0 auth token ──────────────────────────────
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <AUTH_TOKEN>

# ── Pre-configured for Dash0 (edit only if using a different backend) ─
OTEL_SERVICE_NAME=reaper-mcp-server
OTEL_EXPORTER_OTLP_ENDPOINT=https://ingress.eu1.dash0.com
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_RESOURCE_ATTRIBUTES=service.namespace=reaper-mcp,deployment.environment.name=development
