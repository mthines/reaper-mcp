{
  "name": "reaper-mcp-server",
  "sourceRoot": "apps/reaper-mcp-server/src",
  "projectType": "application",
  "tags": ["type:app"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "options": {
        "main": "apps/reaper-mcp-server/src/main.ts",
        "outputPath": "dist/apps/reaper-mcp-server",
        "outputFileName": "main.js",
        "tsConfig": "apps/reaper-mcp-server/tsconfig.json",
        "bundle": true,
        "format": ["esm"],
        "platform": "node",
        "target": "node20",
        "minify": false,
        "sourcemap": true,
        "external": [],
        "assets": [
          {
            "glob": "**/*",
            "input": "reaper",
            "output": "reaper"
          },
          {
            "glob": "**/*",
            "input": "knowledge",
            "output": "knowledge"
          },
          {
            "glob": "**/*",
            "input": ".claude/rules",
            "output": "claude-rules"
          },
          {
            "glob": "**/*",
            "input": ".claude/skills",
            "output": "claude-skills"
          },
          {
            "glob": "**/*",
            "input": ".claude/agents",
            "output": "claude-agents"
          },
          {
            "glob": "README.md",
            "input": ".",
            "output": "."
          },
          {
            "glob": "LICENSE",
            "input": ".",
            "output": "."
          }
        ]
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx --watch apps/reaper-mcp-server/src/main.ts serve",
        "cwd": "{workspaceRoot}"
      }
    },
    "dev:debug": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --inspect --import tsx/esm --watch apps/reaper-mcp-server/src/main.ts serve",
        "cwd": "{workspaceRoot}"
      }
    },
    "dev:otel": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --env-file=.env.otel --import tsx/esm --watch apps/reaper-mcp-server/src/main.ts serve",
        "cwd": "{workspaceRoot}"
      }
    },
    "dev:otel:debug": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --inspect --env-file=.env.otel --import tsx/esm --watch apps/reaper-mcp-server/src/main.ts serve",
        "cwd": "{workspaceRoot}"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/apps/reaper-mcp-server/main.js serve"
      },
      "dependsOn": ["build"]
    }
  }
}
